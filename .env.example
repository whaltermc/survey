# Copy this file to .env for local dev (vercel dev will read it automatically),
# and add the same three variables under Vercel → Project → Settings →
# Environment Variables for production/preview.

# MongoDB Atlas connection string (Atlas → Connect → Drivers).
# Include your database user's username/password in the URI itself.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Optional: database name. Defaults to "habits_survey" if not set.
MONGODB_DB=habits_survey

# The single admin password used to sign in to admin.html.
ADMIN_PASSWORD=choose-a-strong-password

# Any long random string, used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string
